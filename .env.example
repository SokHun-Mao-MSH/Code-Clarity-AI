# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-3-flash-preview"

# Backend CORS allow-list (Render backend). Use "*" for all.
# Example:
# CORS_ORIGINS="https://your-project.web.app,https://your-project.firebaseapp.com"
CORS_ORIGINS="*"

# Backend API URL (for frontend)
# Production frontend (Firebase) should point to Render URL.
VITE_API_URL="https://your-app.onrender.com"
VITE_API_URL_FALLBACK="https://your-app.onrender.com"

# Optional: local development override.
# Leave empty to use same-origin local backend (/api/*).
VITE_API_URL_DEV=""

# Firebase Config (required)
VITE_FIREBASE_API_KEY="your_api_key_here"
VITE_FIREBASE_AUTH_DOMAIN="your_project_id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your_project_id"
VITE_FIREBASE_STORAGE_BUCKET="your_project_id.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="1234567890"
VITE_FIREBASE_APP_ID="1:1234567890:web:abc123def456"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="your_database_id_if_any"
VITE_FIREBASE_MEASUREMENT_ID=""
